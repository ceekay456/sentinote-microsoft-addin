  <Description DefaultValue="Check out and edit documents from VerityOne directly in Word."/>
  <IconUrl DefaultValue="https://localhost:3000/assets/icon-32.png"/>
  <HighResolutionIconUrl DefaultValue="https://localhost:3000/assets/icon-64.png"/>
  <SupportUrl DefaultValue="https://d2yq86j6lz79ng.cloudfront.net"/>
  <AppDomains>
    <AppDomain>https://d2yq86j6lz79ng.cloudfront.net</AppDomain>
    <AppDomain>https://verityone-931097097198.auth.eu-central-1.amazoncognito.com</AppDomain>
    <AppDomain>https://cognito-idp.eu-central-1.amazonaws.com</AppDomain>
    <AppDomain>https://login.microsoftonline.com</AppDomain>
  </AppDomains>
  <Hosts>
    <Host Name="Document"/>
  </Hosts>
  <DefaultSettings>
    <SourceLocation DefaultValue="https://localhost:3000/taskpane.html"/>
